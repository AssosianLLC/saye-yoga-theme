{{- 'saye-kundalini-what.css' | asset_url | stylesheet_tag -}}

<section class="saye-kundalini-what" id="saye-kundalini-what-{{ section.id }}">
  <div class="saye-kundalini-what__container page-width">
    <h2 class="saye-kundalini-what__heading">{{ section.settings.heading | escape }}</h2>
    <p class="saye-kundalini-what__text">{{ section.settings.text | escape }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Kundalini Nedir",
  "tag": "section",
  "class": "saye-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık",
      "default": "Kundalini Nedir?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Metin",
      "default": "Kundalini Yoga, enerji merkezlerini uyandıran ve yüksek bilince erişimi destekleyen bir yoga türüdür. Nefes teknikleri, sesli mantralar, hareketler ve meditasyon bir araya gelir."
    }
  ],
  "presets": [
    {
      "name": "Kundalini Nedir"
    }
  ]
}
{% endschema %}
