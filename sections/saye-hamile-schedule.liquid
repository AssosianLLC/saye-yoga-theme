<section class="saye-hamile-schedule" style="background-color: #ffffff; padding: 48px;">
  <div class="saye-hamile-schedule__container page-width" style="max-width: 800px; margin: 0 auto; text-align: center;">
    
    <h2 class="saye-hamile-schedule__heading" style="font-family: var(--font-heading); font-size: 36px; color: var(--saye-dark); font-weight: 500; margin: 0 0 16px 0;">
      {{ section.settings.heading | default: 'Çarşamba Dersleri' }}
    </h2>

    <p class="saye-hamile-schedule__text" style="font-family: var(--font-body); font-size: 16px; line-height: 1.6; color: var(--saye-dark); margin: 0 0 16px 0;">
      {{ section.settings.text | default: 'Haftalık tema değişir (2. trimesterden 3. trimestere)' }}
    </p>

    <div class="saye-hamile-schedule__small" style="font-family: var(--font-body); font-size: 14px; color: var(--saye-dark); opacity: 0.8; margin: 0;">
      {{ section.settings.small_text | default: 'Tüm kayıtlara 14 gün erişim.' }}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Saye Hamile Schedule",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Çarşamba Dersleri"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Haftalık tema değişir (2. trimesterden 3. trimestere)"
    },
    {
      "type": "text",
      "id": "small_text",
      "label": "Small Text",
      "default": "Tüm kayıtlara 14 gün erişim."
    }
  ],
  "presets": [
    {
      "name": "Saye Hamile Schedule"
    }
  ]
}
{% endschema %}
