<section class="saye-hamile-for-whom" style="background-color: var(--saye-beige); padding: 48px;">
  <div class="saye-hamile-for-whom__container page-width" style="max-width: 800px; margin: 0 auto; background-color: #ffffff; padding: 48px; border-radius: 16px; box-shadow: 0 2px 12px rgba(60,36,21,0.08);">
    
    <h2 class="saye-hamile-for-whom__heading" style="font-family: var(--font-heading); font-size: 36px; color: var(--saye-dark); font-weight: 500; margin: 0 0 32px 0; text-align: center;">
      {{ section.settings.heading | default: 'Hangileri İçin?' }}
    </h2>

    <ul class="saye-hamile-for-whom__list" style="list-style: none; padding: 0; margin: 0; font-family: var(--font-body); font-size: 16px; color: var(--saye-dark); line-height: 1.8;">
      <li style="margin-bottom: 16px; display: flex; align-items: flex-start; gap: 12px;">
        <span style="color: var(--saye-sage); font-weight: bold;">✓</span>
        <span>14. haftadan sonraki hamile kadınlar</span>
      </li>
      <li style="margin-bottom: 16px; display: flex; align-items: flex-start; gap: 12px;">
        <span style="color: var(--saye-sage); font-weight: bold;">✓</span>
        <span>Stüdyoya gidemeyen hamileler</span>
      </li>
      <li style="margin-bottom: 16px; display: flex; align-items: flex-start; gap: 12px;">
        <span style="color: var(--saye-sage); font-weight: bold;">✓</span>
        <span>Doğum öncesinde hazırlık isteyenler</span>
      </li>
      <li style="display: flex; align-items: flex-start; gap: 12px;">
        <span style="color: var(--saye-sage); font-weight: bold;">✓</span>
        <span>Yoga tecrübesi olmayan hamileler (beginner-friendly)</span>
      </li>
    </ul>

  </div>
</section>

{% schema %}
{
  "name": "Saye Hamile For Whom",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hangileri İçin?"
    }
  ],
  "presets": [
    {
      "name": "Saye Hamile For Whom"
    }
  ]
}
{% endschema %}
