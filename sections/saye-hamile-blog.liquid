<section class="saye-hamile-blog" style="background-color: var(--saye-bg); padding: 48px;">
  <div class="saye-hamile-blog__container page-width" style="max-width: 1200px; margin: 0 auto;">
    
    <h3 class="saye-hamile-blog__heading" style="font-family: var(--font-heading); font-size: 24px; color: var(--saye-dark); font-weight: 500; margin: 0 0 32px 0; text-align: center;">
      {{ section.settings.heading | default: 'Hamilelik & Doğum Blogu' }}
    </h3>

    <div class="saye-hamile-blog__grid">
      
      <!-- Card 1 -->
      <div class="saye-hamile-blog__card" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 12px rgba(60,36,21,0.08);">
        <div class="saye-hamile-blog__image-wrapper" style="width: 100%; height: 200px; background-color: var(--saye-beige);">
          {{ 'image' | placeholder_svg_tag: 'saye-hamile-blog__image-placeholder' }}
        </div>
        <div class="saye-hamile-blog__content" style="padding: 24px;">
          <h4 class="saye-hamile-blog__title" style="font-family: var(--font-heading); font-size: 20px; color: var(--saye-dark); margin: 0 0 12px 0;">Hamilelikte Güvenli Pozlar</h4>
          <p class="saye-hamile-blog__excerpt" style="font-family: var(--font-body); font-size: 14px; color: var(--saye-dark); line-height: 1.6; margin: 0 0 16px 0; opacity: 0.8;">Hangi asanaların hamilelik döneminde daha güvenli olduğunu ve nelere dikkat etmeniz gerektiğini öğrenin.</p>
          <a href="/blogs/hamilelik/guvenli-pozlar" class="saye-hamile-blog__link" style="font-family: var(--font-body); font-size: 14px; color: var(--saye-sage); text-decoration: underline; font-weight: 500;">Oku →</a>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="saye-hamile-blog__card" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 12px rgba(60,36,21,0.08);">
        <div class="saye-hamile-blog__image-wrapper" style="width: 100%; height: 200px; background-color: var(--saye-beige);">
          {{ 'image' | placeholder_svg_tag: 'saye-hamile-blog__image-placeholder' }}
        </div>
        <div class="saye-hamile-blog__content" style="padding: 24px;">
          <h4 class="saye-hamile-blog__title" style="font-family: var(--font-heading); font-size: 20px; color: var(--saye-dark); margin: 0 0 12px 0;">Doğuma Hazırlık Nefesi</h4>
          <p class="saye-hamile-blog__excerpt" style="font-family: var(--font-body); font-size: 14px; color: var(--saye-dark); line-height: 1.6; margin: 0 0 16px 0; opacity: 0.8;">Nefes egzersizlerinin doğuma hazırlık sürecindeki yerini ve rahatlatıcı etkilerini keşfedin.</p>
          <a href="/blogs/hamilelik/dogum-nefesi" class="saye-hamile-blog__link" style="font-family: var(--font-body); font-size: 14px; color: var(--saye-sage); text-decoration: underline; font-weight: 500;">Oku →</a>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="saye-hamile-blog__card" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 12px rgba(60,36,21,0.08);">
        <div class="saye-hamile-blog__image-wrapper" style="width: 100%; height: 200px; background-color: var(--saye-beige);">
          {{ 'image' | placeholder_svg_tag: 'saye-hamile-blog__image-placeholder' }}
        </div>
        <div class="saye-hamile-blog__content" style="padding: 24px;">
          <h4 class="saye-hamile-blog__title" style="font-family: var(--font-heading); font-size: 20px; color: var(--saye-dark); margin: 0 0 12px 0;">Pelvik Taban Egzersizleri</h4>
          <p class="saye-hamile-blog__excerpt" style="font-family: var(--font-body); font-size: 14px; color: var(--saye-dark); line-height: 1.6; margin: 0 0 16px 0; opacity: 0.8;">Sağlıklı bir hamilelik ve doğum için pelvik taban kaslarını güçlendirmenin yolları.</p>
          <a href="/blogs/hamilelik/pelvik-taban" class="saye-hamile-blog__link" style="font-family: var(--font-body); font-size: 14px; color: var(--saye-sage); text-decoration: underline; font-weight: 500;">Oku →</a>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .saye-hamile-blog__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  .saye-hamile-blog__image-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    fill: #ffffff;
  }
  @media screen and (min-width: 768px) {
    .saye-hamile-blog__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Saye Hamile Blog",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hamilelik & Doğum Blogu"
    }
  ],
  "presets": [
    {
      "name": "Saye Hamile Blog"
    }
  ]
}
{% endschema %}
