{{- 'saye-kundalini-blog.css' | asset_url | stylesheet_tag -}}

<section class="saye-kundalini-blog" id="saye-kundalini-blog-{{ section.id }}">
  <div class="saye-kundalini-blog__container page-width">
    <h3 class="saye-kundalini-blog__heading">{{ section.settings.heading | escape }}</h3>
    
    <div class="saye-kundalini-blog__grid">
      {% for block in section.blocks %}
        <div class="saye-kundalini-blog__card" {{ block.shopify_attributes }}>
          <div class="saye-kundalini-blog__image-wrapper">
            {% if block.settings.image != blank %}
              <img class="saye-kundalini-blog__image" src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'saye-kundalini-blog__image' }}
            {% endif %}
          </div>
          <div class="saye-kundalini-blog__content">
            <h4 class="saye-kundalini-blog__title">{{ block.settings.title | escape }}</h4>
            <p class="saye-kundalini-blog__excerpt">{{ block.settings.excerpt | escape }}</p>
            <a href="{{ block.settings.link }}" class="saye-kundalini-blog__link">Oku →</a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kundalini Blog",
  "tag": "section",
  "class": "saye-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık",
      "default": "Kundalini Yoga Pratikleri Blogu"
    }
  ],
  "blocks": [
    {
      "type": "blog_card",
      "name": "Blog Kartı",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Görsel"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Başlık",
          "default": "Blog Yazısı Başlığı"
        },
        {
          "type": "textarea",
          "id": "excerpt",
          "label": "Özet",
          "default": "Bu blog yazısının kısa bir özeti burada yer alacak."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kundalini Blog",
      "blocks": [
        {
          "type": "blog_card"
        },
        {
          "type": "blog_card"
        },
        {
          "type": "blog_card"
        }
      ]
    }
  ]
}
{% endschema %}
