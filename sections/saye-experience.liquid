{{- 'saye-experience.css' | asset_url | stylesheet_tag -}}

<section class="saye-experience" id="saye-experience-{{ section.id }}">
  <div class="saye-experience__container page-width">
    <h2 class="saye-experience__heading">Deneyim</h2>
    <p class="saye-experience__text">Gülşen Bozdoğan, 15+ yıldır yoga ve meditasyon pratiğinde. Kundalini yolculuğu KRI eğitimiyle derinleşti; o günden bu yana 8 yıldır aktif ders veriyor. Saye Yoga, kendi pratiğinden doğan bir ihtiyacın — erişilebilir, küçük grup, yaşamın akışına uyan yoga — cevabıdır.</p>
  </div>
</section>

